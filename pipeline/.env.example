# Copia este archivo a ".env" (sin ".example") y completa los valores reales.
# ".env" nunca se sube a git (ver .gitignore).

# --- YouTube Data API v3 (OAuth "Desktop app") ---
# client_id y client_secret salen del client_secret_*.json descargado en
# Google Cloud Console (APIs y servicios > Credenciales).
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Dónde se guarda el token ya autorizado. Se crea solo: la primera vez que
# subas un clip se abre el navegador para pedir permiso una vez; desde la
# segunda vez en adelante se reusa este archivo sin volver a pedir login.
YOUTUBE_TOKEN_FILE=youtube_token.json

# --- Supabase (proyecto compartido con otro uso; tabla en schema rayando_cda) ---
SUPABASE_URL=
# Service role key (NO la anon key) — necesaria para insertar en la tabla.
SUPABASE_SERVICE_ROLE_KEY=
